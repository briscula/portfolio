{
  "version": 2,
  "buildCommand": "pnpm --filter @repo/database db:generate && pnpm build && node scripts/copy-workspace-deps.js",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    }
  ]
}